<!DOCTYPE html>
<html>
<head>
    <title>字符串格式化工具</title>
    <style>
        textarea { width: 100%; height: 100px; }
        .container { max-width: 800px; margin: 0 auto; }
    </style>
</head>
<body>
    <div class="container">
        <h1>字符串格式化工具</h1>
        <p>输入要格式化的文本（将规范逗号后的空格并去除多余空格）:</p>
        <textarea id="inputText"></textarea>
        <button onclick="formatText()">格式化</button>
        <h3>结果:</h3>
        <textarea id="outputText" readonly></textarea>
    </div>

    <script>
        function formatText() {
            let input = document.getElementById('inputText').value;
            // 替换逗号后的任意空格为", "
            let formatted = input.replace(/,\s*/g, ', ');
            // 替换所有多余空格为单个空格
            formatted = formatted.split(/\s+/).join(' ');
            document.getElementById('outputText').value = formatted;
        }
    </script>
</body>
</html>
